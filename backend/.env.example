# Backend Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# Security
SECRET_KEY=your-secret-key-change-this-in-production

# User Credentials - Change these!
USER_A_PASSWORD=secure-password-for-user-a
USER_Z_PASSWORD=secure-password-for-user-z
ADMIN_PASSWORD=secure-password-for-admin

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Logging
LOG_LEVEL=INFO

# Optional: Enable CORS for specific domains
# CORS_ORIGINS=http://localhost:5173,http://192.168.1.100:8000
